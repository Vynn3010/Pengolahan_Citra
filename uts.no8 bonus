import tkinter as tk
from tkinter import ttk, filedialog, messagebox
import numpy as np
import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg
from PIL import Image, ImageTk
import cv2
from scipy.ndimage import uniform_filter, median_filter as scipy_median
import math

# ============================================================
# MAIN APPLICATION
# ============================================================
class AplikasiPCD(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Aplikasi Pengolahan Citra Digital - UTS PCD")
        self.geometry("1100x700")
        self.configure(bg="#1e1e2e")
        self.resizable(True, True)

        self.img_path = None
        self.img_asli = None
        self.img_array = None

        self.buat_header()
        self.buat_sidebar()
        self.buat_area_tampil()
        self.buat_statusbar()

    # ----------------------------------------------------------
    # HEADER
    # ----------------------------------------------------------
    def buat_header(self):
        frame = tk.Frame(self, bg="#313244", pady=10)
        frame.pack(fill="x")
        tk.Label(frame, text="🖼  Aplikasi Pengolahan Citra Digital",
                 font=("Segoe UI", 16, "bold"),
                 bg="#313244", fg="#cdd6f4").pack()
        tk.Label(frame, text="UTS Pengolahan Citra Digital | PCD-2 s/d PCD-5",
                 font=("Segoe UI", 9),
                 bg="#313244", fg="#a6adc8").pack()

    # ----------------------------------------------------------
    # SIDEBAR TOMBOL
    # ----------------------------------------------------------
    def buat_sidebar(self):
        self.sidebar = tk.Frame(self, bg="#181825", width=220)
        self.sidebar.pack(side="left", fill="y", padx=0, pady=0)
        self.sidebar.pack_propagate(False)

        tk.Label(self.sidebar, text="MENU", font=("Segoe UI", 10, "bold"),
                 bg="#181825", fg="#89b4fa").pack(pady=(15, 5))

        # Tombol buka file
        self.buat_tombol(self.sidebar, "📂  Buka Foto", self.buka_foto,
                         "#89b4fa", "#1e1e2e")

        tk.Label(self.sidebar, text="── Soal 2 ──",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "🎨  Konversi RGB/Gray/Biner",
                         self.soal2_konversi, "#a6e3a1", "#1e1e2e")

        tk.Label(self.sidebar, text="── Soal 3 ──",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "📊  Kuantisasi Citra",
                         self.soal3_kuantisasi, "#f9e2af", "#1e1e2e")

        tk.Label(self.sidebar, text="── Soal 4 ──",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "☀  Brightness & Contrast",
                         self.soal4_brightness, "#fab387", "#1e1e2e")

        tk.Label(self.sidebar, text="── Soal 5 ──",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "📈  Histogram Equalization",
                         self.soal5_histeq, "#cba6f7", "#1e1e2e")

        tk.Label(self.sidebar, text="── Soal 6 ──",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "🔧  Filter Noise",
                         self.soal6_filter, "#89dceb", "#1e1e2e")

        tk.Label(self.sidebar, text="── Soal 7 ──",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "📄  Scanner Dokumen",
                         self.soal7_scanner, "#f38ba8", "#1e1e2e")

        tk.Label(self.sidebar, text="──────────",
                 font=("Segoe UI", 8), bg="#181825", fg="#585b70").pack(pady=(10,2))
        self.buat_tombol(self.sidebar, "🗑  Bersihkan",
                         self.bersihkan, "#6c7086", "#cdd6f4")

    def buat_tombol(self, parent, teks, perintah, bg, fg):
        btn = tk.Button(parent, text=teks, command=perintah,
                        font=("Segoe UI", 9, "bold"),
                        bg=bg, fg=fg, relief="flat",
                        padx=10, pady=6, cursor="hand2",
                        activebackground="#cdd6f4", activeforeground="#1e1e2e")
        btn.pack(fill="x", padx=12, pady=3)

    # ----------------------------------------------------------
    # AREA TAMPIL UTAMA
    # ----------------------------------------------------------
    def buat_area_tampil(self):
        self.frame_tampil = tk.Frame(self, bg="#1e1e2e")
        self.frame_tampil.pack(side="left", fill="both", expand=True, padx=10, pady=10)

        self.label_info = tk.Label(self.frame_tampil,
                                   text="Silakan buka foto terlebih dahulu  ←",
                                   font=("Segoe UI", 12),
                                   bg="#1e1e2e", fg="#585b70")
        self.label_info.pack(expand=True)

    def buat_statusbar(self):
        self.status_var = tk.StringVar(value="Siap.")
        bar = tk.Label(self, textvariable=self.status_var,
                       font=("Segoe UI", 8), bg="#313244", fg="#a6adc8",
                       anchor="w", padx=10)
        bar.pack(side="bottom", fill="x")

    def set_status(self, pesan):
        self.status_var.set(pesan)
        self.update_idletasks()

    # ----------------------------------------------------------
    # TAMPILKAN FIGURE MATPLOTLIB DI DALAM TKINTER
    # ----------------------------------------------------------
    def tampil_figure(self, fig):
        for widget in self.frame_tampil.winfo_children():
            widget.destroy()
        canvas = FigureCanvasTkAgg(fig, master=self.frame_tampil)
        canvas.draw()
        canvas.get_tk_widget().pack(fill="both", expand=True)
        plt.close(fig)

    # ----------------------------------------------------------
    # BUKA FOTO
    # ----------------------------------------------------------
    def buka_foto(self):
        path = filedialog.askopenfilename(
            filetypes=[("Image files", "*.jpg *.jpeg *.png *.bmp")])
        if not path:
            return
        self.img_path = path
        self.img_asli = Image.open(path).convert('RGB')

        # Resize jika terlalu besar
        maks = 800
        w, h = self.img_asli.size
        if max(w, h) > maks:
            skala = maks / max(w, h)
            self.img_asli = self.img_asli.resize(
                (int(w*skala), int(h*skala)), Image.LANCZOS)

        self.img_array = np.array(self.img_asli)
        w2, h2 = self.img_asli.size

        # Tampilkan preview
        fig, ax = plt.subplots(figsize=(6, 5), facecolor="#1e1e2e")
        ax.imshow(self.img_array)
        ax.set_title("Foto Asli", color="#cdd6f4", fontsize=12)
        ax.axis('off')
        fig.patch.set_facecolor("#1e1e2e")
        self.tampil_figure(fig)
        self.set_status(f"Foto dibuka: {path} | Ukuran: {w2} x {h2} piksel")

    def cek_foto(self):
        if self.img_array is None:
            messagebox.showwarning("Peringatan", "Buka foto terlebih dahulu!")
            return False
        return True

    def bersihkan(self):
        for widget in self.frame_tampil.winfo_children():
            widget.destroy()
        self.label_info = tk.Label(self.frame_tampil,
                                   text="Silakan buka foto terlebih dahulu  ←",
                                   font=("Segoe UI", 12),
                                   bg="#1e1e2e", fg="#585b70")
        self.label_info.pack(expand=True)
        self.set_status("Layar dibersihkan.")

    # ----------------------------------------------------------
    # SOAL 2: KONVERSI RGB / GRAYSCALE / BINER
    # ----------------------------------------------------------
    def soal2_konversi(self):
        if not self.cek_foto(): return
        self.set_status("Memproses konversi citra...")

        rgb   = self.img_array
        gray  = np.array(self.img_asli.convert('L'))
        biner = (gray > 128).astype(np.uint8) * 255

        fig, axes = plt.subplots(1, 3, figsize=(12, 4), facecolor="#1e1e2e")
        fig.suptitle("Soal 2 – Konversi Representasi Citra",
                     color="#cdd6f4", fontsize=12)

        data = [(rgb, "RGB\n{}".format(rgb.shape), None),
                (gray, "Grayscale\n{}".format(gray.shape), 'gray'),
                (biner, "Biner (threshold=128)\n{}".format(biner.shape), 'gray')]

        for ax, (img, judul, cmap) in zip(axes, data):
            ax.imshow(img, cmap=cmap)
            ax.set_title(judul, color="#cdd6f4", fontsize=9)
            ax.axis('off')
            ax.set_facecolor("#1e1e2e")

        # Info memori
        total = rgb.shape[0] * rgb.shape[1]
        info = (f"Memori  RGB: {rgb.nbytes:,} bytes | "
                f"Gray: {gray.nbytes:,} bytes | "
                f"Biner: {total//8:,} bytes (teoritis)")
        fig.text(0.5, 0.01, info, ha='center', color="#a6adc8", fontsize=8)
        plt.tight_layout()
        self.tampil_figure(fig)
        self.set_status("Soal 2 selesai. " + info)

    # ----------------------------------------------------------
    # SOAL 3: KUANTISASI
    # ----------------------------------------------------------
    def soal3_kuantisasi(self):
        if not self.cek_foto(): return
        self.set_status("Memproses kuantisasi...")

        gray = np.array(self.img_asli.convert('L'), dtype=np.float32)

        def kuantisasi(arr, n):
            step = 256 / n
            return (np.floor(arr / step) * step + step/2).clip(0,255).astype(np.uint8)

        levels = [2, 4, 8, 16]
        fig, axes = plt.subplots(1, 5, figsize=(16, 4), facecolor="#1e1e2e")
        fig.suptitle("Soal 3 – Kuantisasi Citra Grayscale",
                     color="#cdd6f4", fontsize=12)

        axes[0].imshow(gray.astype(np.uint8), cmap='gray', vmin=0, vmax=255)
        axes[0].set_title("Asli\n(256 level, 8 bit)", color="#cdd6f4", fontsize=9)
        axes[0].axis('off')

        for ax, lv in zip(axes[1:], levels):
            bit = int(math.log2(lv))
            hasil = kuantisasi(gray, lv)
            ax.imshow(hasil, cmap='gray', vmin=0, vmax=255)
            ax.set_title(f"{lv} Level\n({bit} bit/piksel)",
                         color="#cdd6f4", fontsize=9)
            ax.axis('off')

        plt.tight_layout()
        self.tampil_figure(fig)
        self.set_status("Soal 3 selesai.")

    # ----------------------------------------------------------
    # SOAL 4: BRIGHTNESS & CONTRAST STRETCHING
    # ----------------------------------------------------------
    def soal4_brightness(self):
        if not self.cek_foto(): return
        self.set_status("Memproses brightness & contrast...")

        gray = np.array(self.img_asli.convert('L'), dtype=np.float32)
        bright = np.clip(gray + 80, 0, 255).astype(np.uint8)
        i_min, i_max = gray.min(), gray.max()
        contrast = ((gray - i_min) / (i_max - i_min) * 255).astype(np.uint8)

        fig, axes = plt.subplots(2, 3, figsize=(13, 8), facecolor="#1e1e2e")
        fig.suptitle("Soal 4 – Brightness & Contrast Stretching",
                     color="#cdd6f4", fontsize=12)

        pasangan = [
            (gray.astype(np.uint8), "Asli", "#a6adc8"),
            (bright, "Setelah Brightness (+80)", "#f9e2af"),
            (contrast, "Setelah Contrast Stretching", "#89b4fa")
        ]

        for i, (img, judul, warna) in enumerate(pasangan):
            axes[0, i].imshow(img, cmap='gray', vmin=0, vmax=255)
            axes[0, i].set_title(judul, color=warna, fontsize=9)
            axes[0, i].axis('off')

            axes[1, i].hist(img.flatten(), bins=256, range=(0,255),
                            color=warna, edgecolor='none', alpha=0.8)
            axes[1, i].set_facecolor("#181825")
            axes[1, i].tick_params(colors="#a6adc8")
            axes[1, i].set_xlim([0, 255])
            for spine in axes[1, i].spines.values():
                spine.set_edgecolor("#585b70")

        plt.tight_layout()
        self.tampil_figure(fig)
        self.set_status(f"Soal 4 selesai. Min asli={int(i_min)}, Max asli={int(i_max)}")

    # ----------------------------------------------------------
    # SOAL 5: HISTOGRAM EQUALIZATION
    # ----------------------------------------------------------
    def soal5_histeq(self):
        if not self.cek_foto(): return
        self.set_status("Memproses histogram equalization...")

        gray = np.array(self.img_asli.convert('L'))
        total = gray.size

        hist = np.zeros(256, dtype=np.int64)
        for v in range(256):
            hist[v] = np.sum(gray == v)

        cdf = np.cumsum(hist)
        cdf_min = cdf[cdf > 0].min()
        cdf_norm = np.round(
            (cdf - cdf_min) / (total - cdf_min) * 255
        ).astype(np.uint8)
        eq = cdf_norm[gray]

        hist_eq = np.zeros(256, dtype=np.int64)
        for v in range(256):
            hist_eq[v] = np.sum(eq == v)

        fig, axes = plt.subplots(2, 2, figsize=(11, 8), facecolor="#1e1e2e")
        fig.suptitle("Soal 5 – Histogram Equalization",
                     color="#cdd6f4", fontsize=12)

        axes[0,0].imshow(gray, cmap='gray', vmin=0, vmax=255)
        axes[0,0].set_title("Foto Asli", color="#a6adc8", fontsize=9)
        axes[0,0].axis('off')

        axes[0,1].imshow(eq, cmap='gray', vmin=0, vmax=255)
        axes[0,1].set_title("Setelah Equalization", color="#cba6f7", fontsize=9)
        axes[0,1].axis('off')

        for ax, h, warna, judul in [
            (axes[1,0], hist, "#a6adc8", "Histogram Asli"),
            (axes[1,1], hist_eq, "#cba6f7", "Histogram Setelah Equalization")
        ]:
            ax.bar(range(256), h, color=warna, width=1, edgecolor='none')
            ax.set_title(judul, color=warna, fontsize=9)
            ax.set_facecolor("#181825")
            ax.set_xlim([0, 255])
            ax.tick_params(colors="#a6adc8")
            for spine in ax.spines.values():
                spine.set_edgecolor("#585b70")

        plt.tight_layout()
        self.tampil_figure(fig)
        self.set_status(
            f"Soal 5 selesai. Rata-rata asli={gray.mean():.1f} "
            f"→ sesudah={eq.mean():.1f}")

    # ----------------------------------------------------------
    # SOAL 6: FILTER NOISE
    # ----------------------------------------------------------
    def soal6_filter(self):
        if not self.cek_foto(): return
        self.set_status("Menambahkan noise dan memproses filter...")

        arr = self.img_array.copy()
        total = arr.shape[0] * arr.shape[1]
        jumlah = int(total * 0.05)

        noise = arr.copy()
        ry = np.random.randint(0, arr.shape[0], jumlah//2)
        rx = np.random.randint(0, arr.shape[1], jumlah//2)
        noise[ry, rx] = [255,255,255]
        ry = np.random.randint(0, arr.shape[0], jumlah//2)
        rx = np.random.randint(0, arr.shape[1], jumlah//2)
        noise[ry, rx] = [0,0,0]

        mean_r = np.stack([uniform_filter(noise[:,:,c], size=3)
                           for c in range(3)], axis=2).astype(np.uint8)
        med_r  = np.stack([scipy_median(noise[:,:,c], size=3)
                           for c in range(3)], axis=2).astype(np.uint8)

        mse_n = np.mean((arr.astype(np.float32)-noise.astype(np.float32))**2)
        mse_m = np.mean((arr.astype(np.float32)-mean_r.astype(np.float32))**2)
        mse_d = np.mean((arr.astype(np.float32)-med_r.astype(np.float32))**2)

        fig, axes = plt.subplots(1, 4, figsize=(16, 5), facecolor="#1e1e2e")
        fig.suptitle("Soal 6 – Mean Filter vs Median Filter",
                     color="#cdd6f4", fontsize=12)

        data = [
            (arr,    f"Asli"),
            (noise,  f"+ Noise (5%)\nMSE={mse_n:.1f}"),
            (mean_r, f"Mean Filter 3×3\nMSE={mse_m:.1f}"),
            (med_r,  f"Median Filter 3×3\nMSE={mse_d:.1f}")
        ]

        for ax, (img, judul) in zip(axes, data):
            ax.imshow(img)
            ax.set_title(judul, color="#cdd6f4", fontsize=9)
            ax.axis('off')

        plt.tight_layout()
        self.tampil_figure(fig)
        self.set_status(
            f"Soal 6 selesai. MSE Noise={mse_n:.1f} | "
            f"Mean={mse_m:.1f} | Median={mse_d:.1f}")

    # ----------------------------------------------------------
    # SOAL 7: SCANNER DOKUMEN
    # ----------------------------------------------------------
    def soal7_scanner(self):
        if not self.cek_foto(): return
        self.set_status("Memproses scanner dokumen...")

        img_cv = cv2.cvtColor(self.img_array, cv2.COLOR_RGB2BGR)
        h_asli, w_asli = img_cv.shape[:2]

        gray   = cv2.cvtColor(img_cv, cv2.COLOR_BGR2GRAY)
        blur   = cv2.GaussianBlur(gray, (5,5), 0)
        tepi   = cv2.Canny(blur, 50, 150)
        dilated = cv2.dilate(tepi, np.ones((3,3), np.uint8), iterations=1)

        contours, _ = cv2.findContours(dilated, cv2.RETR_EXTERNAL,
                                        cv2.CHAIN_APPROX_SIMPLE)
        contours = sorted(contours, key=cv2.contourArea, reverse=True)

        sudut = None
        for cnt in contours[:5]:
            eps   = 0.02 * cv2.arcLength(cnt, True)
            approx = cv2.approxPolyDP(cnt, eps, True)
            if len(approx) == 4:
                sudut = approx
                break

        img_kontur = img_cv.copy()
        if sudut is not None:
            cv2.drawContours(img_kontur, [sudut], -1, (0,255,0), 3)
            status_kontur = "Kontur 4 sudut ditemukan"
        else:
            cnt_b = contours[0]
            x,y,w,h = cv2.boundingRect(cnt_b)
            sudut = np.array([[[x,y]],[[x+w,y]],[[x+w,y+h]],[[x,y+h]]])
            cv2.rectangle(img_kontur,(x,y),(x+w,y+h),(0,255,0),3)
            status_kontur = "Fallback bounding rect"

        def urutkan(pts):
            pts = pts.reshape(4,2).astype(np.float32)
            hasil = np.zeros((4,2), dtype=np.float32)
            s = pts.sum(axis=1)
            hasil[0] = pts[np.argmin(s)]
            hasil[2] = pts[np.argmax(s)]
            d = np.diff(pts, axis=1)
            hasil[1] = pts[np.argmin(d)]
            hasil[3] = pts[np.argmax(d)]
            return hasil

        pts = urutkan(sudut)
        dx = pts[1][0] - pts[0][0]
        dy = pts[1][1] - pts[0][1]
        sudut_deg = np.degrees(np.arctan2(dy, dx))

        pusat = (w_asli//2, h_asli//2)
        M_rot = cv2.getRotationMatrix2D(pusat, sudut_deg, 1.0)
        img_rot = cv2.warpAffine(img_cv, M_rot, (w_asli, h_asli),
                                  borderMode=cv2.BORDER_REPLICATE)

        pts_rot = cv2.transform(pts.reshape(1,4,2), M_rot).reshape(4,2)
        pts_rot = urutkan(pts_rot.reshape(4,1,2))
        x1 = max(0, int(pts_rot[:,0].min()))
        y1 = max(0, int(pts_rot[:,1].min()))
        x2 = min(w_asli, int(pts_rot[:,0].max()))
        y2 = min(h_asli, int(pts_rot[:,1].max()))
        img_crop = img_rot[y1:y2, x1:x2]

        W = int(max(np.linalg.norm(pts[1]-pts[0]),
                    np.linalg.norm(pts[2]-pts[3])))
        H = int(max(np.linalg.norm(pts[3]-pts[0]),
                    np.linalg.norm(pts[2]-pts[1])))
        pts_dst = np.array([[0,0],[W-1,0],[W-1,H-1],[0,H-1]],
                            dtype=np.float32)
        M_persp = cv2.getPerspectiveTransform(pts, pts_dst)
        img_persp = cv2.warpPerspective(img_cv, M_persp, (W, H))

        def bgr2rgb(img):
            return cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

        fig, axes = plt.subplots(1, 4, figsize=(18, 5), facecolor="#1e1e2e")
        fig.suptitle("Soal 7 – Transformasi Geometrik: Simulasi Scanner",
                     color="#cdd6f4", fontsize=12)

        data = [
            (bgr2rgb(img_cv),    "1. Foto Asli"),
            (bgr2rgb(img_kontur),"2. Deteksi Kontur"),
            (bgr2rgb(img_crop),  "3. Koreksi & Crop"),
            (bgr2rgb(img_persp), "4. Perspektif (Scanner)")
        ]

        for ax, (img, judul) in zip(axes, data):
            ax.imshow(img)
            ax.set_title(judul, color="#cdd6f4", fontsize=9)
            ax.axis('off')

        plt.tight_layout()
        self.tampil_figure(fig)
        self.set_status(
            f"Soal 7 selesai. {status_kontur} | "
            f"Sudut={sudut_deg:.2f}° | Crop={img_crop.shape[1]}×{img_crop.shape[0]}")

